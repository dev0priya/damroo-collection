# Runtime app URL settings
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# Neon PostgreSQL
# Use pooled Neon URL for app runtime. Hostname usually contains -pooler.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
# Use direct Neon URL for Prisma migrations/admin tooling.
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
COOKIE_NAME=damroo_session

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
